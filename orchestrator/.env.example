# Casper Testnet
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc
CASPER_NETWORK=casper-test
# Locally this is a path to the key file. In the cloud (no filesystem) set it to
# the key's PEM contents instead; the same applies to every *_KEY var below.
CASPER_SECRET_KEY=../.keys/casper/secret_key.pem
TRIBUNAL_CONTRACT_HASH=
CSPR_CLOUD_KEY=

# Per-judge Casper keys (each verdict is signed by its judge's own key so
# reputation accrues per judge). Optional locally: they default to
# ../.keys/casper/judges/<facet>.pem. In the cloud set each to the PEM contents.
CASPER_JUDGE_AUTHENTICITY=
CASPER_JUDGE_SOLVENCY=
CASPER_JUDGE_CUSTODIAN=
CASPER_JUDGE_VALUATION=

# GenLayer (the tribunal's own account; generate with scripts/genlayer-keygen.mjs)
GENLAYER_CHAIN=studionet
GENLAYER_ENDPOINT=
GENLAYER_DEPLOYER_KEY=../.keys/genlayer/deployer.key

# Per-judge GenLayer accounts, so the four judges can run concurrently instead of
# sharing the deployer's nonce. Optional locally: default to
# ../.keys/genlayer/judges/<facet>.key. In the cloud set each to the 0x… key.
GENLAYER_JUDGE_AUTHENTICITY=
GENLAYER_JUDGE_SOLVENCY=
GENLAYER_JUDGE_CUSTODIAN=
GENLAYER_JUDGE_VALUATION=

# One deployed FacetJudge per facet (the panel). Deploy each with:
#   genlayer deploy --contract judges/facet_judge.py --args "<FacetName>" "<rubric>"
GENLAYER_AUTHENTICITY_JUDGE=
GENLAYER_SOLVENCY_JUDGE=
GENLAYER_CUSTODIAN_JUDGE=
GENLAYER_VALUATION_JUDGE=
